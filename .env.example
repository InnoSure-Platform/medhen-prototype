# Medhen Platform — environment template (production mesh)
# Copy to .env and fill Telebirr sandbox credentials from Ethio Telecom.

# PostgreSQL (shared schema for Phase 0 mesh demo; split per BC in Phase 1 prod)
DATABASE_URL=postgres://medhen:medhen@localhost:5432/medhen?sslmode=disable
PG_SCHEMA=pc_medhen

# Kafka / Valkey
KAFKA_BROKERS=localhost:19092
REDIS_URL=redis://localhost:6379/0

# Keycloak JWT (gateway validates Bearer tokens)
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=medhen
KEYCLOAK_AUDIENCE=pc-gateway

# Telebirr sandbox (leave empty to use mock adapter)
TELEBIRR_BASE_URL=https://sandbox.ethiotelecom.et
TELEBIRR_APP_ID=
TELEBIRR_APP_SECRET=
TELEBIRR_SHORT_CODE=
TELEBIRR_NOTIFY_URL=http://localhost:8080/api/v1/webhooks/telebirr
TELEBIRR_RETURN_URL=http://localhost:3000/quote
TELEBIRR_RECEIVER=EIC Medhen

# MinIO (document-svc object store — optional Phase 0)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=medhen
MINIO_SECRET_KEY=medhenmedhen
MINIO_BUCKET=medhen-docs

# Mesh gateway routing
MEDHEN_MESH=1
PARTY_URL=http://localhost:8101
POLICY_URL=http://localhost:8103
BILLING_URL=http://localhost:8107
CLAIMS_URL=http://localhost:8106
AUDIT_URL=http://localhost:8117
INTEGRATION_URL=http://localhost:8118

MEDHEN_DOCS_DIR=./data/docs
