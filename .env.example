# Medhen Platform — environment template (modular monolith).
# Copy to .env and fill in real values.

# --- Runtime ---------------------------------------------------------------
MEDHEN_ENV=dev
MEDHEN_HTTP_ADDR=:8080
MEDHEN_DOCS_DIR=./data/docs

# --- PostgreSQL ------------------------------------------------------------
# One database, one migration set (internal/platform/migrate). Tables live in the
# public schema; tenant isolation is enforced by row-level security.
#
# For LOCAL dev the app may connect as the DB owner (superuser bypasses RLS).
# In NON-LOCAL envs, connect as the least-privilege role provisioned by the
# security migration (RLS then enforces tenant isolation) and REQUIRE TLS:
#   DATABASE_URL=postgres://medhen_app:<secret>@db.host:5432/medhen?sslmode=require
# The app warns at boot if MEDHEN_ENV!=dev and sslmode=disable (M10).
DATABASE_URL=postgres://medhen:medhen@localhost:5432/medhen?sslmode=disable

# How often the outbox relay drains (Go duration).
MEDHEN_OUTBOX_POLL=1s

# --- Keycloak (auth kernel; RS256/JWKS) ------------------------------------
# Auth is fail-closed: it activates only when KEYCLOAK_URL + KEYCLOAK_REALM are
# set, and never falls back to an insecure mode.
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=medhen
KEYCLOAK_AUDIENCE=medhen-api

# --- Telebirr --------------------------------------------------------------
# HMAC-SHA256 secret used to verify Telebirr payment webhooks (billing module).
TELEBIRR_WEBHOOK_SECRET=
