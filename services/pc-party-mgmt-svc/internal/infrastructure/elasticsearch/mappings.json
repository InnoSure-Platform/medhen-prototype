{
  "settings": {
    "analysis": {
      "analyzer": {
        "autocomplete_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "autocomplete_filter"]
        },
        "fuzzy_match_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase"]
        }
      },
      "filter": {
        "autocomplete_filter": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 20
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "tenant_id": { "type": "keyword" },
      "first_name": { "type": "text", "analyzer": "autocomplete_analyzer" },
      "last_name": { "type": "text", "analyzer": "autocomplete_analyzer" },
      "dob": { "type": "date" },
      "national_id_number": { "type": "keyword" }
    }
  }
}
