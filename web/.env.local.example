# pc-web — local environment

# Monolith API — SERVER-ONLY (not NEXT_PUBLIC): API calls are proxied through
# the Next route handler at /api/medhen/* which attaches the token + tenant
# server-side (C5). The browser never talks to the monolith directly.
MEDHEN_API=http://localhost:8080
MEDHEN_TENANT=eic

NEXT_PUBLIC_AUTH_REQUIRED=true

# Keycloak (server-side login route + optional public hints)
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=medhen
KEYCLOAK_CLIENT=pc-web
KEYCLOAK_ISSUER=http://localhost:8081/realms/medhen

# REQUIRED — no insecure fallback. The app refuses to start if these are unset.
# KEYCLOAK_SECRET must equal the pc-web client secret set in Keycloak via
# scripts/keycloak-configure.sh (KEYCLOAK_PC_WEB_SECRET). Generate a strong,
# random NEXTAUTH_SECRET, e.g.: openssl rand -base64 32
KEYCLOAK_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
NEXT_PUBLIC_KEYCLOAK_REALM=medhen
NEXT_PUBLIC_KEYCLOAK_CLIENT=pc-web
