# Copy to .env.local for local dev. NEVER commit real secrets.
# Auth (NextAuth + Keycloak). Fail closed at runtime — no hardcoded fallbacks.
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
KEYCLOAK_ISSUER=http://localhost:8081/realms/medhen
KEYCLOAK_CLIENT=pc-web
KEYCLOAK_SECRET=            # must equal the pc-web client secret in Keycloak
KEYCLOAK_URL=http://localhost:8081
# Exposed to the browser only for the Keycloak account-console deep link (no secret).
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8081/realms/medhen

# Server-only upstream to the Go monolith (NOT NEXT_PUBLIC_*): the browser never
# sees this or the access token — traffic flows through /api/medhen.
MEDHEN_API=http://localhost:8080
MEDHEN_TENANT=eic
# Comma-separated tenants a client may select (server-side allowlist enforced by
# the proxy). Defaults to MEDHEN_TENANT. The UI list is NEXT_PUBLIC_MEDHEN_TENANTS.
MEDHEN_ALLOWED_TENANTS=eic
NEXT_PUBLIC_MEDHEN_TENANTS=eic

# Error tracking (optional — no-ops when unset). Server + browser DSNs.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_MEDHEN_ENV=development
