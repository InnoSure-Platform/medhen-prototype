{
  "realm": "medhen",
  "enabled": true,
  "displayName": "Medhen Platform",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "verifyEmail": true,
  "editUsernameAllowed": false,
  "rememberMe": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1,
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@eic-et.com",
    "fromDisplayName": "Medhen · EIC",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "pc-gateway",
      "name": "Medhen Gateway",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["http://localhost:8080"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "pc-web",
      "name": "Medhen Web",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "customer", "description": "Policyholder self-service" },
      { "name": "agent", "description": "Intermediary / branch agent" },
      { "name": "staff", "description": "EIC operations staff" },
      { "name": "claims", "description": "Claims handler" },
      { "name": "admin", "description": "Platform administrator" }
    ]
  },
  "defaultRoles": ["customer"],
  "users": [
    {
      "username": "demo-agent",
      "enabled": true,
      "emailVerified": true,
      "email": "agent@eic-et.com",
      "firstName": "Demo",
      "lastName": "Agent",
      "credentials": [{ "type": "password", "value": "medhen-demo", "temporary": false }],
      "realmRoles": ["agent", "staff"]
    },
    {
      "username": "demo-claims",
      "enabled": true,
      "emailVerified": true,
      "email": "claims@eic-et.com",
      "firstName": "Demo",
      "lastName": "Claims",
      "credentials": [{ "type": "password", "value": "medhen-demo", "temporary": false }],
      "realmRoles": ["claims", "staff"]
    },
    {
      "username": "demo-customer",
      "enabled": true,
      "emailVerified": true,
      "email": "customer@eic-et.com",
      "firstName": "Demo",
      "lastName": "Customer",
      "credentials": [{ "type": "password", "value": "medhen-demo", "temporary": false }],
      "realmRoles": ["customer"]
    },
    {
      "username": "demo-admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@eic-et.com",
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "medhen-demo", "temporary": false }],
      "realmRoles": ["admin", "staff"]
    }
  ]
}
