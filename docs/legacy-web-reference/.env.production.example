# Vercel / Production Environment Template for pc-web

# Monolith API — SERVER-ONLY (not NEXT_PUBLIC). Calls are proxied through
# /api/medhen/* which attaches the token + tenant server-side (C5).
MEDHEN_API=http://localhost:8080
MEDHEN_TENANT=eic

# Keycloak Authentication Configuration
KEYCLOAK_CLIENT=pc-web
KEYCLOAK_ISSUER=http://localhost:8081/realms/medhen
# The pc-web confidential client secret — set in the deployment secret store,
# never commit a real value here.
KEYCLOAK_SECRET=REPLACE_ME

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_ME
